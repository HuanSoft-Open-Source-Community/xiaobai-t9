<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <appSettings>
        <!-- 强制 SendKeys 使用 SendInput API，避免 JournalHook 模式在 UI 线程阻塞时死锁 -->
        <add key="SendKeys" value="SendInput"/>
    </appSettings>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
</configuration>